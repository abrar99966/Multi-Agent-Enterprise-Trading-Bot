# Environment template for local dev. Two consumers, one file:
#
#   1. docker compose -- copy to infra/.env. Compose reads it automatically
#      when run from infra/ and uses only the POSTGRES_* values.
#   2. Python backend -- copy (or merge) into a .env at the REPO ROOT.
#      backend/app/core/config.py (Settings) reads ./.env relative to the
#      process working directory and only honours ETB_-prefixed keys.
#
# Local-dev credentials only. Never reuse these values outside localhost.

# --- docker compose: postgres bootstrap --------------------------------------
POSTGRES_USER=etb
POSTGRES_PASSWORD=etb_local_dev
POSTGRES_DB=etb

# --- backend: app.core.config.Settings (env_prefix ETB_) ---------------------
# Empty string disables the adapter (journal-only / SQLite-only mode, the
# Phase 0 default). Set these only when the compose stack is up.
ETB_REDPANDA_BROKERS=localhost:9092
ETB_QUESTDB_ILP_HOST=localhost

# Durable bar store (SQLite) and hash-chained event journal, relative to the
# backend process working directory. Used with or without docker.
ETB_BAR_DB_PATH=data/market_data.db
ETB_JOURNAL_DIR=data/journal

# --- slow-path LLM analyst (vendor-agnostic; slowpath/providers.py) ----------
# provider: stub (default, no external model) | anthropic | openai | groq |
#           together | openrouter | gemini | ollama | lmstudio | deepseek |
#           mistral | xai | openai_compatible (then set ETB_LLM_BASE_URL).
# Switching models is a config change, never a code change. Examples:
#   free/local : ETB_LLM_PROVIDER=ollama  ETB_LLM_MODEL=llama3.1   (no key)
#   free tier  : ETB_LLM_PROVIDER=groq    ETB_LLM_MODEL=llama-3.3-70b-versatile
#   paid       : ETB_LLM_PROVIDER=openai  ETB_LLM_MODEL=gpt-4o-mini
#   paid       : ETB_LLM_PROVIDER=gemini  ETB_LLM_MODEL=gemini-2.0-flash
#   paid       : ETB_LLM_PROVIDER=anthropic ETB_LLM_MODEL=claude-opus-4-8
#   any OpenAI-compatible host: ETB_LLM_PROVIDER=openai_compatible ETB_LLM_BASE_URL=https://host/v1
ETB_LLM_PROVIDER=stub
ETB_LLM_MODEL=
ETB_LLM_API_KEY=
ETB_LLM_BASE_URL=
ETB_LLM_TIMEOUT_S=30

# --- classic (Part-1) frontend link (dashboard sidebar) -----------------------
# The new dashboard at /dash links to the old UI and its broker page; the link
# shows "offline" until the classic app is reachable at this URL.
ETB_LEGACY_UI_URL=http://localhost:3000
ETB_LEGACY_UI_BROKERS_PATH=/brokers
